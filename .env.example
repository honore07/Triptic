# === BASE ===
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173

# === BASE DE DONNÉES (optionnel en dev : fallback in-memory) ===
DATABASE_URL=postgresql://triptic_user:password@localhost:5432/triptic_db
REDIS_URL=redis://localhost:6379

# === AUTH ===
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
JWT_SECRET=xxx

# === IA ===
# Provider principal (deepseek). Sans clé Deepseek, fallback automatique Anthropic.
DEEPSEEK_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# === CARTOGRAPHIE ===
MAPBOX_PUBLIC_TOKEN=pk.xxx
MAPBOX_SECRET_TOKEN=sk.xxx

# === PHOTOS ===
UNSPLASH_ACCESS_KEY=xxx
PEXELS_API_KEY=xxx

# === PAIEMENTS ===
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# === EMAILS ===
RESEND_API_KEY=re_xxx

# === BASE DE CONNAISSANCE DES LIEUX ===
# Flux DATAtourisme (espace diffuseur → Flux + Applications → clé API)
DATATOURISME_WEBSERVICE_URL=https://diffuseur.datatourisme.fr/webservice/xxx/xxx

# === FRONTEND (préfixe VITE_ requis) ===
VITE_API_URL=http://localhost:3001
VITE_MAPBOX_PUBLIC_TOKEN=pk.xxx
